# Tavily API key for web search
TAVILY_API_KEY=your_tavily_api_key_here

# LangSmith API keys for tracing
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=ishtar_ai
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Hugging Face token for accessing restricted models (REQUIRED for Llama 4)
HUGGING_FACE_TOKEN=your_huggingface_token_here

# Pinecone configuration for vector storage
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_pinecone_environment
PINECONE_INDEX=ishtar

# News API for news retrieval
NEWSAPI_KEY=your_newsapi_key_here 