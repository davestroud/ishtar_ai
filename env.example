# Ishtar AI – Environment Variables

# --- Core Requirements ---
# OpenAI API Key (for embeddings used by FAISS)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Meta Llama API Key (for language model)
# You can use either LLAMA_API_KEY or the more generic LLM_API_KEY
LLAMA_API_KEY=llama-xxxxxxxxxxxxxxxxxxxxxxxx
# LLM_API_KEY=

# --- Optional Services & Configurations ---
# Tavily API Key (for real-time web search)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxx

# FAISS Configuration
# Path where the FAISS index files (.faiss and .pkl) will be stored/loaded.
# Defaults to "./faiss_index" if not set.
FAISS_INDEX_PATH=./faiss_index

# Llama Model Configuration (Optional - defaults are in pipeline.py)
# LLAMA_API_URL=https://api.llama.com/v1/
# LLAMA_MODEL=Llama-4-Maverick-17B-128E-Instruct-FP8

# OpenAI Embedding Model (Optional - defaults to text-embedding-ada-002)
# OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# LangSmith Tracing (Optional - for debugging and monitoring LangChain pipelines)
# LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Logging Level (Optional - defaults to INFO, e.g., DEBUG, WARNING, ERROR)
# LOG_LEVEL=INFO

# --- Deprecated / No Longer Used with current FAISS setup ---
# PINECONE_API_KEY=
# PINECONE_ENVIRONMENT=
# PINECONE_INDEX=
# PINECONE_HOST=
# HF_TOKEN= 